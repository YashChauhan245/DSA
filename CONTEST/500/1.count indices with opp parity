https://leetcode.com/problems/count-indices-with-opposite-parity/description/

class Solution {
public:
    vector<int> countOppositeParity(vector<int>& nums) {
        int n=nums.size();
        vector<int>result(n);
            for(int i=0;i<n;i++){
                int score=0;
                for(int j=i+1;j<n;j++){
                    //i->even and j->odd
                    if(nums[i]%2==0 && nums[j]%2!=0){
                        score++;
                    }
                    if(nums[i]%2!=0 && nums[j]%2==0){
                        score++;
                    }
                }
                result[i]=score;
            }
        return result;
    }
};
